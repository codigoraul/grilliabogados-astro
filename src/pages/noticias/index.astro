---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { getPosts } from '../../lib/wp';

const base = '/prueba/';
const posts = await getPosts();
---

<Layout title="Noticias · Grilli Abogados" description="Noticias de interés jurídico, novedades legales y artículos de Grilli Abogados en Temuco, La Araucanía.">
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-navy-deep pt-[90px] overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 20% 80%, #D1B787 0%, transparent 50%), radial-gradient(circle at 80% 20%, #D1B787 0%, transparent 50%);"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 py-20 relative">
      <nav class="flex items-center gap-2 text-white/40 text-xs font-inter mb-8">
        <a href={base} class="hover:text-gold transition-colors">Inicio</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gold">Noticias</span>
      </nav>
      <div class="max-w-3xl">
        <span class="tag-pill mb-4 inline-block">Actualidad</span>
        <h1 class="font-cinzel text-white font-semibold leading-tight mb-6" style="font-size: clamp(1.5rem, 5vw, 2.6rem);">
          Noticias de <span class="text-gold">Interés</span>
        </h1>
        <p class="text-white/65 text-lg leading-relaxed">
          Novedades legales, artículos y noticias relevantes para usted y su familia, seleccionadas por nuestro equipo.
        </p>
      </div>
    </div>
    <div class="h-12 relative">
      <svg class="absolute bottom-0 w-full" viewBox="0 0 1440 48" preserveAspectRatio="none">
        <path d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z" fill="#F7F3EE"/>
      </svg>
    </div>
  </section>

  <!-- Posts -->
  <section class="bg-cream-pale py-16">
    <div class="max-w-6xl mx-auto px-6">
      {posts.length === 0 ? (
        <div class="text-center py-20">
          <p class="font-cinzel text-2xl mb-3" style="color: rgb(65,65,67);">Pronto publicaremos noticias</p>
          <p class="text-warm text-sm">Estamos preparando contenido de interés. Vuelva pronto.</p>
        </div>
      ) : (
        <>
          <!-- Grid: cards verticales, 3 columnas -->
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {posts.map((p, i) => (
              <a
                href={`${base}noticias/${p.slug}`}
                class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-lg transition-all duration-400 hover:-translate-y-1.5 flex flex-col"
                style={`animation-delay: ${i * 80}ms`}
              >
                <div class="relative h-48 overflow-hidden">
                  {p.image ? (
                    <img src={p.image} alt={p.imageAlt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-navy-deep flex items-center justify-center">
                      <span class="font-cinzel text-gold/40 text-3xl">G</span>
                    </div>
                  )}
                  <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/60 to-transparent"></div>
                  {p.categories[0] && (
                    <div class="absolute bottom-3 left-4">
                      <span class="text-xs font-bold uppercase tracking-widest font-inter px-2.5 py-1 rounded-full" style="background:rgba(209,183,135,0.2);color:#D1B787;border:1px solid rgba(209,183,135,0.35)">{p.categories[0]}</span>
                    </div>
                  )}
                </div>
                <div class="p-6 flex flex-col flex-1">
                  <span class="text-warm text-xs font-inter mb-2">{p.dateFormatted}</span>
                  <h3 class="font-cinzel font-semibold mb-2 group-hover:text-gold transition-colors duration-200 leading-snug" style="color: rgb(65,65,67); font-size: 1.1rem;">{p.title}</h3>
                  <p class="text-warm text-sm leading-relaxed flex-1">{p.excerpt.slice(0, 130)}{p.excerpt.length > 130 ? '…' : ''}</p>
                  <div class="mt-5 pt-4 border-t border-cream flex items-center justify-between">
                    <span class="text-gold text-sm font-semibold font-inter">Leer más</span>
                    <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors">
                      <svg class="w-4 h-4 stroke-gold transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>
