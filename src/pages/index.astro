---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import ContactForm from '../components/ContactForm.astro';
import { services } from '../data/services';
const base = '/prueba/';
---

<Layout title="Grilli Abogados – Servicios Jurídicos, Mediación y Selección de Personal | Temuco">
  <Navbar />

  <!-- ══ HERO SLIDER ══ -->
  <section id="heroSlider" class="relative overflow-hidden h-[660px] pt-[90px]">
    <div id="slidesTrack" class="flex h-full transition-transform duration-700 ease-[cubic-bezier(0.77,0,0.18,1)]">

      <!-- Slide 1: Representación Judicial -->
      <div class="slide relative min-w-full h-full flex items-center bg-cover bg-center"
           style="background-image: linear-gradient(135deg,rgba(26,30,48,0.94) 45%,rgba(70,75,105,0.78) 100%), url('https://images.unsplash.com/photo-1589829545856-d10d557cf95f?w=1600&q=80')">
        <div class="max-w-6xl mx-auto px-6 w-full">
          <div class="slide-content max-w-2xl">
            <div class="slide-eyebrow flex items-center gap-3 text-gold text-xs font-bold tracking-[0.18em] uppercase mb-6 opacity-0">
              <span class="block w-8 h-0.5 bg-gold shrink-0"></span>
              Temuco · 25 años de experiencia
            </div>
            <h1 class="font-cinzel text-white text-4xl md:text-5xl leading-tight mb-5 opacity-0">
              Representación judicial con <em class="text-gold not-italic">estrategia real</em> y resultados
            </h1>
            <p class="text-white/75 text-base md:text-lg max-w-xl mb-9 opacity-0">
              Representamos personas y empresas ante juicios civiles, laborales, familiares y patrimoniales con estrategia sólida y defensa efectiva.
            </p>
            <div class="flex gap-3 flex-wrap opacity-0">
              <a href={`${base}servicios/defensa-judicial`} class="btn-gold">Ver área judicial</a>
              <a href={`${base}contacto`} class="btn-outline-gold">Consultar mi caso</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Slide 2: Selección de Personal -->
      <div class="slide relative min-w-full h-full flex items-center bg-cover bg-center"
           style="background-image: linear-gradient(135deg,rgba(26,30,48,0.88) 40%,rgba(70,75,105,0.82) 100%), url('/prueba/images/servicios/seleccion-personal.webp')">
        <div class="max-w-6xl mx-auto px-6 w-full">
          <div class="slide-content max-w-2xl">
            <div class="slide-eyebrow inline-flex items-center gap-2 bg-gold/15 border border-gold/35 text-gold text-xs font-bold tracking-wider uppercase px-4 py-1.5 rounded-full mb-6 opacity-0">
              <svg class="w-3.5 h-3.5 fill-gold" viewBox="0 0 24 24"><path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM16 11l2 2 4-4"/></svg>
              Servicios Psicosociales
            </div>
            <h1 class="font-cinzel text-white text-4xl md:text-5xl leading-tight mb-5 opacity-0">
              Selección de Personal <em class="text-gold not-italic">estratégica</em>
            </h1>
            <p class="text-white/75 text-base md:text-lg max-w-xl mb-9 opacity-0">
              Evaluamos, seleccionamos y apoyamos la contratación de perfiles estratégicos para empresas de La Araucanía.
            </p>
            <div class="flex gap-3 flex-wrap opacity-0">
              <a href={`${base}servicios/seleccion-personal`} class="btn-gold text-sm px-8 py-3.5">Ver servicio</a>
              <a href={`${base}contacto`} class="btn-outline-gold">Enviar CV</a>
            </div>
          </div>
        </div>
      </div>

      <!-- Slide 3: Negligencia Médica -->
      <div class="slide relative min-w-full h-full flex items-center bg-cover bg-center"
           style="background-image: linear-gradient(135deg,rgba(26,30,48,0.85) 40%,rgba(46,50,73,0.80) 100%), url('/prueba/images/servicios/negligencia-medica.webp')">
        <div class="max-w-6xl mx-auto px-6 w-full">
          <div class="slide-content max-w-2xl">
            <div class="slide-eyebrow inline-flex items-center gap-2 bg-gold/15 border border-gold/35 text-gold text-xs font-bold tracking-wider uppercase px-4 py-1.5 rounded-full mb-6 opacity-0">
              <svg class="w-3.5 h-3.5 fill-gold" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              Área de Alta Especialización
            </div>
            <h1 class="font-cinzel text-white text-4xl md:text-5xl leading-tight mb-5 opacity-0">
              Negligencia médica: <em class="text-gold not-italic">exija sus derechos</em>
            </h1>
            <p class="text-white/75 text-base md:text-lg max-w-xl mb-9 opacity-0">
              Mala praxis, errores quirúrgicos, diagnóstico tardío. Demandamos responsabilidad médica y obtenemos indemnización real para nuestros clientes.
            </p>
            <div class="flex gap-3 flex-wrap opacity-0">
              <a href={`${base}servicios/negligencia-medica`} class="btn-gold text-sm px-8 py-3.5">Revisar mi caso</a>
              <a href={`${base}contacto`} class="btn-outline-gold">Evaluación gratuita</a>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /slidesTrack -->

    <!-- Arrows -->
    <button onclick="prevSlide()" aria-label="Anterior"
      class="absolute left-5 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white/10 border border-white/20 backdrop-blur-sm flex items-center justify-center transition-all hover:bg-gold/25 hover:border-gold">
      <svg class="w-5 h-5 stroke-white" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button onclick="nextSlide()" aria-label="Siguiente"
      class="absolute right-5 top-1/2 -translate-y-1/2 z-10 w-11 h-11 rounded-full bg-white/10 border border-white/20 backdrop-blur-sm flex items-center justify-center transition-all hover:bg-gold/25 hover:border-gold">
      <svg class="w-5 h-5 stroke-white" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <!-- Dots -->
    <div class="absolute bottom-7 left-1/2 -translate-x-1/2 z-10 flex gap-2.5">
      <button onclick="goToSlide(0)" class="slider-dot w-2.5 h-2.5 rounded-full bg-gold scale-125 transition-all" aria-label="Slide 1"></button>
      <button onclick="goToSlide(1)" class="slider-dot w-2.5 h-2.5 rounded-full bg-white/35 transition-all" aria-label="Slide 2"></button>
      <button onclick="goToSlide(2)" class="slider-dot w-2.5 h-2.5 rounded-full bg-white/35 transition-all" aria-label="Slide 3"></button>
    </div>

    <!-- Progress bar -->
    <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-white/10 z-10">
      <div id="progressBar" class="h-full bg-gold animate-progress"></div>
    </div>
  </section>

  <!-- ══ INTRO STRIP ══ -->
  <div class="bg-gold py-5">
    <div class="max-w-6xl mx-auto px-6">
      <p class="text-navy-dark font-semibold text-center text-sm tracking-wide">
        Su problema legal merece una defensa seria &nbsp;·&nbsp; Temuco, La Araucanía &nbsp;·&nbsp; Lun–Vie Presencial 09:00–14:00 · Remoto 15:00–18:00 &nbsp;·&nbsp; +569 9844 6799
      </p>
    </div>
  </div>

  <!-- ══ SERVICIOS GRID ══ -->
  <section class="py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-14">
        <span class="tag-pill">Nuestras áreas</span>
        <h2 class="section-title text-3xl md:text-4xl mt-2">Servicios especializados</h2>
        <div class="gold-divider mx-auto"></div>
        <p class="text-warm max-w-lg mx-auto">Más de 25 años resolviendo casos complejos con un equipo multidisciplinario de abogadas y psicólogo.</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(s => (
          <a href={`${base}servicios/${s.slug}`} class="group no-underline">
            <div class="card-service h-full">
              <!-- Image -->
              <div class="relative h-44 overflow-hidden">
                <img
                  src={s.image}
                  alt={s.title}
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-navy-deep/50 group-hover:bg-navy-deep/35 transition-colors duration-300"></div>
                <div class="absolute inset-0 flex items-end p-4">
                  <span class="text-xs font-bold uppercase tracking-widest text-gold bg-navy-deep/60 backdrop-blur-sm px-3 py-1 rounded-full border border-gold/30">
                    {s.tag}
                  </span>
                </div>
              </div>
              <!-- Body -->
              <div class="p-6 flex flex-col flex-1">
                <h3 class="font-cinzel text-navy-deep text-lg mb-2">{s.title}</h3>
                <p class="text-warm text-sm leading-relaxed mb-5 flex-1">{s.shortDesc}</p>
                <span class="inline-flex items-center gap-2 text-gold text-xs font-bold tracking-wider uppercase group-hover:gap-3 transition-all duration-300">
                  Ver área
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ ABOUT SNIPPET ══ -->
  <section class="bg-ivory py-24">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <!-- Image -->
        <div class="relative hidden lg:block">
          <img
            src="/prueba/images/servicios/nosotros-saludo.webp"
            alt="Equipo Grilli Abogados Temuco"
            class="rounded-2xl shadow-card-lg w-full h-[460px] object-cover"
            loading="lazy"
          />
          <div class="absolute -bottom-6 -right-6 bg-gold text-navy-dark rounded-xl px-7 py-5 text-center shadow-card font-cinzel">
            <div class="text-4xl font-bold leading-none">25</div>
            <div class="text-xs mt-1 leading-tight">años de<br/>experiencia</div>
          </div>
        </div>
        <!-- Text -->
        <div>
          <span class="tag-pill">Quiénes somos</span>
          <h2 class="section-title text-3xl md:text-4xl mt-2 mb-4">Detrás de cada caso, hay una persona</h2>
          <div class="gold-divider"></div>
          <blockquote class="border-l-4 border-gold pl-5 my-6 font-cinzel text-navy text-lg leading-relaxed italic">
            "Entendemos que detrás de cada juicio existe una persona que necesita respuestas claras, defensa sólida y resultados concretos."
          </blockquote>
          <p class="text-warm leading-relaxed mb-4">Somos un estudio jurídico en Temuco liderado por <strong class="text-navy-deep">abogadas especialistas</strong> con apoyo interdisciplinario de un psicólogo profesional. Llevamos más de 25 años defendiendo los derechos de personas y familias en la Región de La Araucanía.</p>
          <ul class="space-y-2.5 my-6">
            {[
              'Equipo multidisciplinario: abogadas y psicólogo',
              'Alta especialización en negligencia médica',
              'Confidencialidad absoluta en todos los casos',
              'Estrategia judicial orientada a resultados',
            ].map(item => (
              <li class="flex items-center gap-3 text-sm text-gray-600">
                <span class="w-5 h-5 bg-gold rounded-full flex items-center justify-center shrink-0">
                  <svg class="w-3 h-3 stroke-navy-dark" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
          <div class="flex gap-3 flex-wrap">
            <a href={`${base}nosotros`} class="btn-gold">Conocer el equipo</a>
            <a href={`${base}contacto`} class="btn-outline-gold" style="border-color:#464B69;color:#464B69;">Contactar</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══ POR QUÉ ══ -->
  <section class="bg-navy-deep py-24">
    <div class="max-w-6xl mx-auto px-6 text-center">
      <span class="tag-pill" style="border-color:rgba(209,183,135,0.5);color:#EAD9B5;">Nuestra diferencia</span>
      <h2 class="font-cinzel text-white text-3xl md:text-4xl mt-2">¿Por qué elegir Grilli Abogados?</h2>
      <div class="gold-divider mx-auto"></div>

      <!-- Stats -->
      <div class="flex justify-center gap-16 flex-wrap my-12">
        {[['25','Años de experiencia'],['6','Áreas especializadas'],['100%','Compromiso']].map(([n,l]) => (
          <div class="text-center">
            <div class="font-cinzel text-gold text-5xl leading-none">{n}</div>
            <div class="text-white/50 text-xs uppercase tracking-widest mt-2">{l}</div>
          </div>
        ))}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mt-4">
        {[
          {icon:'M12 2a6 6 0 100 12 6 6 0 000-12zM15.477 12.89L17 22l-5-3-5 3 1.523-9.11', t:'25 años de experiencia', p:'Trayectoria sólida en La Araucanía con resultados comprobados en casos complejos.'},
          {icon:'M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM16 11l2 2 4-4', t:'Atención personalizada', p:'Usted no es un expediente. Comunicación clara y cercana en todo momento del proceso.'},
          {icon:'M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8zM12 9a3 3 0 100 6 3 3 0 000-6z', t:'Estrategia judicial real', p:'Análisis profundo y estrategia diseñada para maximizar sus posibilidades de éxito.'},
          {icon:'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', t:'Defensa sólida', p:'Desarrollamos estrategias de defensa fundamentadas para cada tipo de caso y cliente.'},
          {icon:'M22 12h-4l-3 5-4-10-3 5H2', t:'Alta especialización', p:'Equipo con abogadas y psicólogo para una defensa integral y efectiva en cada área.'},
          {icon:'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10zM9 12l2 2 4-4', t:'Confidencialidad absoluta', p:'Su información protegida bajo los más altos estándares de discreción profesional.'},
          {icon:'M23 6l-13.5 9.5L1 6M1 6h22v14a2 2 0 01-2 2H3a2 2 0 01-2-2V6z', t:'Compromiso con resultados', p:'Su tranquilidad comienza con una buena defensa. Estamos aquí para proteger sus derechos.'},
        ].map(c => (
          <div class="bg-white rounded-xl p-7 border-t-4 border-gold text-left shadow-card transition-all hover:-translate-y-1 hover:shadow-card-lg">
            <div class="w-11 h-11 bg-gold-pale rounded-lg flex items-center justify-center mb-4">
              <svg class="w-5 h-5 stroke-navy" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d={c.icon}/>
              </svg>
            </div>
            <h4 class="font-inter font-bold text-navy-deep text-sm mb-2">{c.t}</h4>
            <p class="text-warm text-sm leading-relaxed">{c.p}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══ EQUIPO ══ -->
  <section class="bg-cream-pale py-24 border-t border-cream">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12">
        <span class="tag-pill mb-3 inline-block">El Equipo</span>
        <h2 class="section-title text-3xl md:text-4xl mt-2">Profesionales comprometidos</h2>
        <div class="gold-divider mx-auto mt-4 w-24"></div>
        <p class="text-warm mt-4 max-w-xl mx-auto">Nuestro equipo combina experiencia jurídica con visión humana para ofrecer una defensa integral.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { initials: 'GG', name: 'Giovanna Grilli Gatica', role: 'Abogada · Directora', desc: 'Más de 25 años de experiencia en litigación estratégica, derecho de familia y derecho laboral en La Araucanía.' },
          { initials: 'VG', name: 'Viviana Grilli Ramos', role: 'Asesora Externa · Compliance y Datos', desc: 'Experta en compliance, protección de datos personales y asesoría regulatoria para empresas e instituciones.' },
          { initials: 'MD', name: 'Maritza De Gregorio Álamos', role: 'Abogada', desc: 'Profesional del derecho integrada al equipo de Grilli Abogados para la atención y representación de clientes.' },
          { initials: 'PV', name: 'Paola Vallejos De Gregorio', role: 'Psicóloga Psicolaboral', desc: 'Especialista en evaluación psicolaboral, selección de personal y acompañamiento psicosocial en procesos jurídicos.' },
          { initials: 'HM', name: 'Heidy Morales Hueche', role: 'Asistente', desc: 'Apoyo integral en la gestión administrativa y atención a clientes del estudio.' },
        ].map(m => (
          <div class="bg-white rounded-2xl shadow-card hover:shadow-card-lg transition-shadow duration-300 overflow-hidden">
            <div class="h-44 bg-navy-deep flex items-center justify-center">
              <span class="font-cinzel text-gold text-5xl font-bold tracking-wide">{m.initials}</span>
            </div>
            <div class="p-6 border-t-4 border-gold">
              <h3 class="font-cinzel text-navy-deep text-lg mb-1">{m.name}</h3>
              <p class="text-gold text-xs font-bold uppercase tracking-widest font-inter mb-3">{m.role}</p>
              <p class="text-warm text-sm leading-relaxed">{m.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/prueba/nosotros#equipo" class="btn-outline-gold px-8 py-3 text-sm">Conocer más del equipo</a>
      </div>
    </div>
  </section>

  <!-- ══ CTA ══ -->
  <section class="bg-navy py-20">
    <div class="max-w-2xl mx-auto px-6 text-center">
      <h2 class="font-cinzel text-white text-3xl mb-4">Su tranquilidad comienza con una buena defensa</h2>
      <p class="text-white/65 mb-3 text-lg">Estamos aquí para proteger sus derechos.</p>
      <p class="text-white/50 mb-10 text-sm">Contáctenos hoy para una evaluación de su caso. Nuestro equipo le responderá a la brevedad.</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href={`${base}contacto`} class="btn-gold">Solicitar consulta</a>
        <a href="https://wa.me/56996426402?text=Hola%2C%20quisiera%20una%20consulta." target="_blank"
           class="inline-flex items-center gap-2.5 bg-[#25D366] text-white font-bold text-sm tracking-widest uppercase px-8 py-3.5 rounded-lg transition-all hover:-translate-y-0.5 hover:bg-[#1ebe5a]">
          <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp ahora
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>

<script>
  let current = 0;
  const total = 3;
  let timer: ReturnType<typeof setInterval>;

  const track = document.getElementById('slidesTrack') as HTMLElement;
  const slides = document.querySelectorAll<HTMLElement>('.slide');
  const dots   = document.querySelectorAll<HTMLButtonElement>('.slider-dot');
  const bar    = document.getElementById('progressBar') as HTMLElement;

  function activateSlide(n: number) {
    slides.forEach(s => {
      const els = s.querySelectorAll<HTMLElement>('.slide-eyebrow, h1, p, .flex');
      els.forEach(el => { el.style.opacity = '0'; el.style.transform = 'translateY(24px)'; });
    });
    const active = slides[n];
    const items = active.querySelectorAll<HTMLElement>('.slide-eyebrow, h1, p, .flex');
    items.forEach((el, i) => {
      setTimeout(() => {
        el.style.transition = `opacity 0.6s ${i * 0.15}s, transform 0.6s ${i * 0.15}s`;
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 50);
    });
  }

  function goToSlide(n: number) {
    current = (n + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dots.forEach((d, i) => {
      d.className = i === current
        ? 'slider-dot w-2.5 h-2.5 rounded-full bg-gold scale-125 transition-all'
        : 'slider-dot w-2.5 h-2.5 rounded-full bg-white/35 transition-all';
    });
    activateSlide(current);
    resetProgress();
  }

  function nextSlide() { goToSlide(current + 1); }
  function prevSlide() { goToSlide(current - 1); }

  function resetProgress() {
    clearInterval(timer);
    bar.style.animation = 'none';
    void bar.offsetWidth;
    bar.style.animation = 'progress 5s linear infinite';
    timer = setInterval(nextSlide, 5000);
  }

  // Init
  activateSlide(0);
  resetProgress();

  document.addEventListener('keydown', e => {
    if (e.key === 'ArrowRight') nextSlide();
    if (e.key === 'ArrowLeft') prevSlide();
  });

  // Expose to onclick
  (window as any).goToSlide = goToSlide;
  (window as any).nextSlide = nextSlide;
  (window as any).prevSlide = prevSlide;
</script>
