---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import ContactForm from '../../components/ContactForm.astro';
import { services, getRelated } from '../../data/services';

export function getStaticPaths() {
  return services.map(s => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const related = getRelated(service.related);
const isAccent = service.highlightAccent;
const accentColor = '#D1B787';
---

<Layout title={`${service.title} · Grilli Abogados`} description={service.shortDesc}>
  <Navbar />

  <!-- Hero del servicio -->
  <section class="relative h-[380px] overflow-hidden flex items-end">
    <img
      src={service.image}
      alt={service.title}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/95 via-navy-deep/55 to-transparent"></div>

    <!-- Breadcrumb -->
    <div class="absolute top-[100px] left-0 right-0">
      <div class="max-w-6xl mx-auto px-6">
        <nav class="flex items-center gap-2 text-white/50 text-xs font-inter">
          <a href="/" class="hover:text-gold transition-colors">Inicio</a>
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <a href="/servicios" class="hover:text-gold transition-colors">Servicios</a>
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          <span class="text-gold">{service.title}</span>
        </nav>
      </div>
    </div>

    <div class="relative max-w-6xl mx-auto px-6 pb-12 w-full">
      <span
        class="inline-block text-xs font-bold uppercase tracking-widest font-inter px-3 py-1 rounded-full mb-4"
        style={`background:${accentColor}22; color:${accentColor}; border:1px solid ${accentColor}44`}
      >
        {service.tag}
      </span>
      <h1 class="font-cinzel text-white text-4xl md:text-5xl font-semibold leading-tight max-w-2xl">
        {service.title}
      </h1>
      <p class="text-white/70 mt-3 text-lg max-w-xl">{service.shortDesc}</p>
    </div>
  </section>

  <!-- Main content -->
  <section class="bg-cream-pale py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">

        <!-- Left: Content -->
        <div class="lg:col-span-2 space-y-10">

          <!-- Descripción -->
          <div>
            <div class="gold-divider mb-6"></div>
            <p class="text-navy-dark text-lg leading-relaxed font-light">{service.longDesc}</p>
          </div>

          <!-- Items del servicio -->
          <div>
            <h2 class="font-cinzel text-navy-deep text-2xl mb-6">¿Qué incluye?</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {service.items.map(item => (
                <div class="flex items-start gap-3 bg-white rounded-xl px-5 py-4 shadow-card">
                  <svg class="w-5 h-5 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style={`stroke:${accentColor}`}>
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  <span class="text-navy-dark text-sm font-medium">{item}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Highlight CTA box -->
          <div
            class="rounded-2xl p-7"
            style={`background:${accentColor}12; border-left: 4px solid ${accentColor}`}
          >
            <div class="flex items-start gap-4">
              <svg class="w-7 h-7 shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style={`stroke:${accentColor}`}>
                <circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              <p class="text-navy-dark leading-relaxed">{service.highlight}</p>
            </div>
          </div>

          <!-- ¿Por qué confiar en nosotros? -->
          <div>
            <h2 class="font-cinzel text-navy-deep text-2xl mb-6">¿Por qué confiar en Grilli Abogados?</h2>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
              {[
                { icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', label: '25 años de experiencia' },
                { icon: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100 8 4 4 0 000-8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75', label: 'Atención personalizada' },
                { icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z', label: 'Defensa sólida y estratégica' },
              ].map(f => (
                <div class="bg-white rounded-xl p-5 shadow-card text-center flex flex-col items-center gap-3">
                  <div class="w-12 h-12 rounded-full flex items-center justify-center" style={`background:${accentColor}18`}>
                    <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style={`stroke:${accentColor}`}>
                      <path d={f.icon}/>
                    </svg>
                  </div>
                  <span class="text-navy-dark text-sm font-semibold font-inter">{f.label}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <a
            href={`https://wa.me/56996426402?text=Hola%2C%20necesito%20asesor%C3%ADa%20en%20${encodeURIComponent(service.title)}.`}
            target="_blank"
            class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-bold text-sm px-7 py-4 rounded-xl shadow-lg transition-all duration-300 hover:-translate-y-0.5"
          >
            <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
          </a>
        </div>

        <!-- Right: Form sticky -->
        <div class="lg:sticky lg:top-24 h-fit">
          <ContactForm
            formId={`form-${service.slug}`}
            title={service.formTitle}
            subtitle="Consulta confidencial · Sin costo"
            btnLabel={service.formBtn}
            accentColor={accentColor}
            showAreaSelect={false}
          />

        </div>
      </div>
    </div>
  </section>

  <!-- Servicios relacionados -->
  {related.length > 0 && (
    <section class="bg-white py-16 border-t border-cream">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="font-cinzel text-navy-deep text-2xl mb-2">Servicios relacionados</h2>
        <div class="gold-divider mb-10"></div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          {related.map(rel => (
            <a href={`/servicios/${rel.slug}`} class="group block bg-cream-pale rounded-2xl overflow-hidden shadow-card hover:shadow-card-lg transition-all duration-300 hover:-translate-y-1">
              <div class="h-44 overflow-hidden">
                <img src={rel.image} alt={rel.title} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy"/>
              </div>
              <div class="p-5">
                <span class="text-xs font-bold uppercase tracking-widest text-gold font-inter">{rel.tag}</span>
                <h3 class="font-cinzel text-navy-deep text-lg mt-1 mb-2">{rel.title}</h3>
                <p class="text-warm text-sm leading-relaxed">{rel.shortDesc}</p>
                <div class="mt-4 flex items-center gap-1 text-gold text-sm font-semibold">
                  Ver más
                  <svg class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer />
  <WhatsAppFloat />
</Layout>
