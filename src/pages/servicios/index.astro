---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { services } from '../../data/services';
const baseUrl = import.meta.env.BASE_URL;
const base = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
---

<Layout title="Servicios · Grilli Abogados" description="Conozca todos los servicios jurídicos, de mediación y selección de personal que ofrece Grilli Abogados en Temuco.">
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-navy-deep pt-[90px] overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 20% 80%, #D1B787 0%, transparent 50%), radial-gradient(circle at 80% 20%, #D1B787 0%, transparent 50%);"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 py-20 relative">
      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-white/40 text-xs font-inter mb-8">
        <a href={base} class="hover:text-gold transition-colors">Inicio</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gold">Servicios</span>
      </nav>
      <div class="max-w-3xl">
        <span class="tag-pill mb-4 inline-block">Nuestras Áreas</span>
        <h1 class="font-cinzel text-white text-4xl md:text-5xl font-semibold leading-tight mb-6">
          Servicios Jurídicos <span class="text-gold">Especializados</span>
        </h1>
        <p class="text-white/65 text-lg leading-relaxed">
          Más de 25 años defendiendo derechos en La Araucanía. Cada caso es único y merece una estrategia personalizada. Encuentre el área legal que necesita.
        </p>
      </div>
    </div>
    <!-- Bottom wave -->
    <div class="h-12 relative">
      <svg class="absolute bottom-0 w-full" viewBox="0 0 1440 48" preserveAspectRatio="none">
        <path d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z" fill="#F7F3EE"/>
      </svg>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-cream-pale py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s, i) => (
          <a
            href={`${base}servicios/${s.slug}`}
            class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-lg transition-all duration-400 hover:-translate-y-1.5 flex flex-col"
            style={`animation-delay: ${i * 80}ms`}
          >
            <!-- Image -->
            <div class="relative h-52 overflow-hidden">
              <img
                src={s.image}
                alt={s.title}
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-navy-deep/70 to-transparent"></div>
              <div class="absolute bottom-4 left-5">
                <span class="text-xs font-bold uppercase tracking-widest font-inter px-2.5 py-1 rounded-full"
                  style={s.highlightAccent
                    ? 'background:rgba(201,76,76,0.25);color:#f89090;border:1px solid rgba(201,76,76,0.4)'
                    : 'background:rgba(209,183,135,0.2);color:#D1B787;border:1px solid rgba(209,183,135,0.35)'}
                >
                  {s.tag}
                </span>
              </div>
              <!-- Icon -->
              <div class="absolute top-4 right-4 w-9 h-9 bg-white/10 backdrop-blur-sm rounded-full flex items-center justify-center border border-white/20">
                <svg class="w-4 h-4 stroke-white" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d={s.iconPath}/>
                </svg>
              </div>
            </div>

            <!-- Content -->
            <div class="p-6 flex flex-col flex-1">
              <h2 class="font-cinzel text-navy-deep text-xl mb-2 group-hover:text-gold transition-colors duration-200">{s.title}</h2>
              <p class="text-warm text-sm leading-relaxed flex-1">{s.shortDesc}</p>

              <!-- Service items preview -->
              <div class="mt-4 space-y-1.5">
                {s.items.slice(0, 3).map(item => (
                  <div class="flex items-center gap-2 text-xs text-navy/70">
                    <svg class="w-3 h-3 shrink-0 stroke-gold" viewBox="0 0 24 24" fill="none" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    {item}
                  </div>
                ))}
                {s.items.length > 3 && (
                  <div class="text-xs text-warm italic pl-5">+{s.items.length - 3} más...</div>
                )}
              </div>

              <div class="mt-5 pt-4 border-t border-cream flex items-center justify-between">
                <span class="text-gold text-sm font-semibold font-inter">Ver detalles</span>
                <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center group-hover:bg-gold/20 transition-colors">
                  <svg class="w-4 h-4 stroke-gold transition-transform duration-200 group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA band -->
  <section class="bg-navy-deep py-16">
    <div class="max-w-4xl mx-auto px-6 text-center">
      <h2 class="font-cinzel text-white text-3xl mb-4">¿No sabe qué área necesita?</h2>
      <p class="text-white/60 text-lg mb-8 leading-relaxed">Cuéntenos su situación y le orientaremos hacia la mejor estrategia legal, sin costo inicial.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href={`${base}contacto`} class="btn-gold px-8 py-4 text-sm">Consulta gratuita</a>
        <a
          href="https://wa.me/56996426402?text=Hola%2C%20necesito%20orientaci%C3%B3n%20legal."
          target="_blank"
          class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-bold text-sm px-7 py-4 rounded-xl transition-all duration-300"
        >
          <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>
