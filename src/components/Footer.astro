---
import { services } from '../data/services';
const base = '/prueba';
---

<footer class="bg-navy-deep text-white/60 pt-14 pb-7">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-10 border-b border-white/8">

      <!-- Brand -->
      <div>
        <img
          src={`${import.meta.env.BASE_URL}logo-grilli-abogados.svg`}
          alt="Grilli Abogados"
          class="h-14 w-auto mb-4 opacity-90"
          onerror="this.style.display='none'"
        />
        <p class="text-sm leading-7">Servicios Jurídicos liderados por abogadas y psicólogo. 25 años defendiendo sus derechos con estrategia, confianza y resultados.</p>
        <p class="text-gold-mid text-xs italic mt-4">Experiencia. Estrategia. Resultados.</p>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-4 font-inter">Servicios</h4>
        <ul class="space-y-2">
          {services.map(s => (
            <li>
              <a href={`${base}servicios/${s.slug}`} class="text-sm text-white/55 hover:text-gold transition-colors duration-200">
                {s.title}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="text-white text-xs font-bold uppercase tracking-widest mb-4 font-inter">Contacto</h4>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <svg class="w-4 h-4 stroke-gold-mid mt-0.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm">Antonio Varas 989, Of. 804<br/>Temuco – La Araucanía</span>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 stroke-gold-mid shrink-0" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.22 1.18 2 2 0 012.22 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.09a16 16 0 006 6l.66-.66a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/>
            </svg>
            <a href="tel:+56996426402" class="text-sm hover:text-gold transition-colors">9 9642 6402</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 stroke-gold-mid shrink-0" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:grilliabogados@gmail.com" class="text-sm hover:text-gold transition-colors">grilliabogados@gmail.com</a>
          </div>
          <div class="flex items-center gap-3">
            <svg class="w-4 h-4 stroke-gold-mid shrink-0" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span class="text-sm">Lun–Vie &nbsp;09:00–18:00</span>
          </div>
        </div>
      </div>
    </div>

    <div class="pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs">
      <span>© 2025–2026 Grilli Abogados · Todos los derechos reservados</span>
      <span>Temuco, Región de La Araucanía</span>
    </div>
  </div>
</footer>
