---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsAppFloat from '../../components/WhatsAppFloat.astro';
import { getPosts, type Post } from '../../lib/wp';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post, related: posts.filter(p => p.slug !== post.slug).slice(0, 3) },
  }));
}

const base = '/prueba/';
const { post, related } = Astro.props as { post: Post; related: Post[] };
---

<Layout title={`${post.title} · Grilli Abogados`} description={post.excerpt}>
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-navy-deep pt-[90px] overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 20% 80%, #D1B787 0%, transparent 50%), radial-gradient(circle at 80% 20%, #D1B787 0%, transparent 50%);"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 py-16 relative">
      <nav class="flex items-center gap-2 text-white/40 text-xs font-inter mb-8 flex-wrap">
        <a href={base} class="hover:text-gold transition-colors">Inicio</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <a href={`${base}noticias`} class="hover:text-gold transition-colors">Noticias</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gold truncate max-w-[200px]">{post.title}</span>
      </nav>
      <div class="flex items-center gap-3 mb-5 flex-wrap">
        {post.categories.slice(0, 3).map(cat => (
          <span class="text-xs font-bold uppercase tracking-widest font-inter px-2.5 py-1 rounded-full" style="background:rgba(209,183,135,0.2);color:#D1B787;border:1px solid rgba(209,183,135,0.35)">{cat}</span>
        ))}
        <span class="text-white/50 text-xs font-inter">{post.dateFormatted}</span>
      </div>
      <h1 class="font-cinzel text-white font-semibold leading-tight" style="font-size: clamp(1.4rem, 4.5vw, 2.3rem);">
        {post.title}
      </h1>
    </div>
    <div class="h-12 relative">
      <svg class="absolute bottom-0 w-full" viewBox="0 0 1440 48" preserveAspectRatio="none">
        <path d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z" fill="#F7F3EE"/>
      </svg>
    </div>
  </section>

  <!-- Cuerpo -->
  <section class="bg-cream-pale py-14">
    <div class="max-w-4xl mx-auto px-6">
      {post.image && (
        <img
          src={post.image}
          alt={post.imageAlt}
          class="w-full max-h-[460px] object-cover rounded-2xl shadow-card mb-10"
          loading="eager"
        />
      )}

      <article class="wp-content bg-white rounded-2xl shadow-card p-8 lg:p-12" set:html={post.content} />

      <!-- CTA -->
      <div class="mt-12 bg-navy-deep rounded-2xl p-8 lg:p-10 text-center">
        <h2 class="font-cinzel text-white text-2xl mb-3">¿Tiene dudas sobre este tema?</h2>
        <p class="text-white/60 mb-6 leading-relaxed">Converse con nuestro equipo. La primera orientación es sin costo.</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={`${base}contacto`} class="btn-gold px-8 py-3.5 text-sm">Consulta gratuita</a>
          <a href="https://wa.me/56996426402" target="_blank" class="inline-flex items-center gap-2 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-bold text-sm px-7 py-3.5 rounded-xl transition-all duration-300">WhatsApp</a>
        </div>
      </div>

      <!-- Relacionadas -->
      {related.length > 0 && (
        <div class="mt-14">
          <h2 class="font-cinzel font-semibold text-xl mb-6" style="color: rgb(65,65,67);">Otras noticias</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            {related.map(p => (
              <a href={`${base}noticias/${p.slug}`} class="group bg-white rounded-2xl overflow-hidden shadow-card hover:shadow-card-lg transition-all duration-300 hover:-translate-y-1">
                <div class="h-36 overflow-hidden">
                  {p.image ? (
                    <img src={p.image} alt={p.imageAlt} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />
                  ) : (
                    <div class="w-full h-full bg-navy-deep flex items-center justify-center"><span class="font-cinzel text-gold/40 text-2xl">G</span></div>
                  )}
                </div>
                <div class="p-5">
                  <span class="text-warm text-xs font-inter">{p.dateFormatted}</span>
                  <h3 class="font-cinzel font-semibold mt-1 text-sm leading-snug group-hover:text-gold transition-colors" style="color: rgb(65,65,67);">{p.title}</h3>
                </div>
              </a>
            ))}
          </div>
        </div>
      )}

      <div class="mt-10 text-center">
        <a href={`${base}noticias`} class="inline-flex items-center gap-2 text-gold text-sm font-semibold font-inter hover:underline">
          <svg class="w-4 h-4 stroke-gold rotate-180" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
          Volver a noticias
        </a>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>

<style is:global>
  /* Estilos para el HTML que viene de WordPress */
  .wp-content { color: rgb(75, 75, 78); font-size: 1rem; line-height: 1.8; }
  .wp-content h2, .wp-content h3, .wp-content h4 { font-family: 'Cinzel', serif; color: #4A3B26; margin: 1.8em 0 0.6em; line-height: 1.3; }
  .wp-content h2 { font-size: 1.45rem; }
  .wp-content h3 { font-size: 1.2rem; }
  .wp-content p { margin: 0 0 1.2em; }
  .wp-content a { color: #A8895A; text-decoration: underline; }
  .wp-content ul, .wp-content ol { margin: 0 0 1.2em 1.4em; }
  .wp-content ul { list-style: disc; }
  .wp-content ol { list-style: decimal; }
  .wp-content li { margin-bottom: 0.4em; }
  .wp-content img { border-radius: 1rem; margin: 1.5em 0; max-width: 100%; height: auto; }
  .wp-content blockquote { border-left: 3px solid #D1B787; padding-left: 1.2em; margin: 1.5em 0; font-style: italic; color: rgb(110,110,112); }
  .wp-content figure { margin: 1.5em 0; }
  .wp-content figcaption { font-size: 0.8rem; color: rgb(140,140,142); text-align: center; margin-top: 0.5em; }
  .wp-content iframe { max-width: 100%; border-radius: 1rem; }
  .wp-content table { width: 100%; border-collapse: collapse; margin: 1.5em 0; font-size: 0.9rem; }
  .wp-content th, .wp-content td { border: 1px solid #e8e0d3; padding: 0.6em 0.9em; text-align: left; }
  .wp-content th { background: #F7F3EE; }
</style>
