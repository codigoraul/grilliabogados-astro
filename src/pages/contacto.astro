---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import ContactForm from '../components/ContactForm.astro';
const base = '/prueba/';
---

<Layout title="Contacto · Grilli Abogados" description="Contáctenos en Temuco. Consulta legal sin costo inicial. Antonio Varas 989, Of. 804 — Tel: 9 9642 6402.">
  <Navbar />

  <!-- Hero -->
  <section class="relative bg-navy-deep pt-[90px] overflow-hidden">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: radial-gradient(circle at 30% 70%, #D1B787 0%, transparent 50%)"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 py-16 relative">
      <nav class="flex items-center gap-2 text-white/40 text-xs font-inter mb-8">
        <a href={base} class="hover:text-gold transition-colors">Inicio</a>
        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-gold">Contacto</span>
      </nav>
      <div class="max-w-2xl">
        <span class="tag-pill mb-4 inline-block">Estamos para ayudarle</span>
        <h1 class="font-cinzel text-white text-4xl md:text-5xl font-semibold leading-tight mb-4">
          Hable con un <span class="text-gold">abogado hoy</span>
        </h1>
        <p class="text-white/65 text-lg leading-relaxed">
          Sin costo inicial. Confidencial. Respuesta rápida. Nuestro equipo está listo para escucharle y orientarle sobre su situación legal.
        </p>
      </div>
    </div>
    <div class="h-12 relative">
      <svg class="absolute bottom-0 w-full" viewBox="0 0 1440 48" preserveAspectRatio="none">
        <path d="M0,48 C360,0 1080,0 1440,48 L1440,48 L0,48 Z" fill="#F7F3EE"/>
      </svg>
    </div>
  </section>

  <!-- Contact section -->
  <section class="bg-cream-pale py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Left: Info + Map -->
        <div class="lg:col-span-2 space-y-8">

          <!-- Contact cards -->
          <div>
            <h2 class="font-cinzel text-navy-deep text-2xl mb-2">Información de contacto</h2>
            <div class="gold-divider mb-6"></div>

            <div class="space-y-4">
              {[
                {
                  icon: 'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z M12 10a2 2 0 100 4 2 2 0 000-4',
                  title: 'Oficina',
                  content: 'Antonio Varas 989, Of. 804',
                  sub: 'Temuco, La Araucanía',
                  href: 'https://maps.google.com/?q=Antonio+Varas+989+Temuco',
                  linkLabel: 'Ver en mapa'
                },
                {
                  icon: 'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.22 1.18 2 2 0 012.22 1h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 8.09a16 16 0 006 6l.66-.66a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z',
                  title: 'Teléfono',
                  content: '9 9642 6402',
                  sub: 'Llamada directa',
                  href: 'tel:+56996426402',
                  linkLabel: 'Llamar ahora'
                },
                {
                  icon: 'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
                  title: 'Correo electrónico',
                  content: 'grilliabogados@gmail.com',
                  sub: 'Respuesta en 24h',
                  href: 'mailto:grilliabogados@gmail.com',
                  linkLabel: 'Enviar email'
                },
                {
                  icon: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z M12 6v6l4 2',
                  title: 'Horario de atención',
                  content: 'Lunes a Viernes',
                  sub: '09:00 – 18:00 hrs.',
                  href: null,
                  linkLabel: null
                },
              ].map(c => (
                <div class="bg-white rounded-xl p-5 shadow-card flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full bg-gold/12 flex items-center justify-center shrink-0">
                    <svg class="w-5 h-5 stroke-gold" viewBox="0 0 24 24" fill="none" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d={c.icon}/>
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-xs font-bold uppercase tracking-widest text-warm font-inter mb-0.5">{c.title}</p>
                    <p class="text-navy-dark font-semibold text-sm">{c.content}</p>
                    <p class="text-warm text-xs mt-0.5">{c.sub}</p>
                    {c.href && (
                      <a href={c.href} target={c.href.startsWith('http') ? '_blank' : undefined} class="text-gold text-xs font-semibold mt-1.5 inline-flex items-center gap-1 hover:underline">
                        {c.linkLabel}
                        <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
                      </a>
                    )}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="bg-navy-deep rounded-2xl p-6 text-center">
            <h3 class="font-cinzel text-white text-lg mb-2">¿Prefiere WhatsApp?</h3>
            <p class="text-white/55 text-sm mb-5">Respuesta inmediata durante horario de oficina</p>
            <a
              href="https://wa.me/56996426402?text=Hola%2C%20quisiera%20una%20consulta%20legal."
              target="_blank"
              class="inline-flex items-center gap-3 bg-[#25D366] hover:bg-[#1ebe5d] text-white font-bold text-sm px-6 py-3.5 rounded-xl shadow-lg transition-all duration-300 hover:-translate-y-0.5 w-full justify-center"
            >
              <svg class="w-5 h-5 fill-white" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Escribir por WhatsApp
            </a>
          </div>

          <!-- Map embed -->
          <div class="rounded-2xl overflow-hidden shadow-card-lg border border-cream">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3070.6!2d-72.5963!3d-38.7358!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x96145cfa79e53701%3A0x0!2sAntonio%20Varas%20989%2C%20Temuco!5e0!3m2!1ses!2scl!4v1699999999999"
              width="100%"
              height="220"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Grilli Abogados - Ubicación"
            ></iframe>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="lg:col-span-3">
          <ContactForm
            formId="contacto-main"
            title="Envíenos su consulta"
            subtitle="Sin costo inicial · Respuesta en 24 horas"
            btnLabel="ENVIAR CONSULTA"
            accentColor="#D1B787"
            showAreaSelect={true}
          />

          <!-- FAQ rápido -->
          <div class="mt-8 bg-white rounded-2xl shadow-card p-7">
            <h3 class="font-cinzel text-navy-deep text-lg mb-5">Preguntas frecuentes</h3>
            <div class="space-y-4" id="faq">
              {[
                { q: '¿La primera consulta tiene costo?', a: 'No. La evaluación inicial de su caso es completamente gratuita y sin compromisos.' },
                { q: '¿Atienden fuera de Temuco?', a: 'Sí, atendemos clientes en toda la Región de La Araucanía. También podemos coordinar consultas por videollamada.' },
                { q: '¿Cuánto demora una respuesta?', a: 'Respondemos todas las consultas dentro de las 24 horas hábiles. Por WhatsApp la respuesta es inmediata.' },
                { q: '¿Trabajan en casos de negligencia médica?', a: 'Sí, es una de nuestras áreas de mayor especialización, con casos en el sistema público y privado.' },
              ].map((f, i) => (
                <div class="border-b border-cream last:border-0 pb-4 last:pb-0">
                  <button
                    class="w-full flex items-start justify-between gap-4 text-left group"
                    onclick={`toggleFaq(${i})`}
                  >
                    <span class="font-semibold text-navy-dark text-sm">{f.q}</span>
                    <svg id={`faq-icon-${i}`} class="w-4 h-4 stroke-gold shrink-0 mt-0.5 transition-transform duration-200" viewBox="0 0 24 24" fill="none" stroke-width="2.5">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </button>
                  <div id={`faq-ans-${i}`} class="hidden mt-2 text-warm text-sm leading-relaxed">{f.a}</div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
  <WhatsAppFloat />
</Layout>

<script>
  function toggleFaq(i: number) {
    const ans = document.getElementById(`faq-ans-${i}`);
    const icon = document.getElementById(`faq-icon-${i}`);
    if (ans && icon) {
      const open = !ans.classList.contains('hidden');
      ans.classList.toggle('hidden', open);
      icon.style.transform = open ? '' : 'rotate(180deg)';
    }
  }
  (window as any).toggleFaq = toggleFaq;
</script>
